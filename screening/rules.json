  {
    "name": "CUI",
    "description": "Carbon and low alloy steel with external insulation in a common CUI temperature range are susceptible to corrosion under insulation when moisture ingress is possible.",
    "required_fields": ["material", "temperature_c", "insulation_present"],
    "conditions": [
      {
        "field": "insulation_present",
        "operator": "equals",
        "value": true,
        "score": 4,
        "label": "Insulation is present",
        "gate": true
      },
      {
        "field": "material",
        "operator": "contains_any",
        "value": ["carbon steel", "cs", "low alloy steel"],
        "score": 3,
        "label": "Material is carbon or low alloy steel",
        "gate": true
      },
      {
        "field": "temperature_c",
        "operator": "between",
        "value": [0, 175],
        "score": 3,
        "label": "Temperature is within simplified CUI range",
        "gate": true
      }
    ],
    "minimum_score": 6
  },
